# Part A: Hawk/Dove Scoring

## Lexicon Definition

```{r lexicons}
# Hawkish language: phrases associated with tightening bias, above-target
# inflation concerns, and removal of monetary accommodation.
hawk_terms <- c(
  "raise rates", "rate hikes", "tighten", "tightening", "restrictive",
  "further increases", "higher for longer", "above target",
  "inflation remains high", "inflation remains elevated",
  "fight inflation", "remove accommodation", "normalize policy",
  "reduce balance sheet", "quantitative tightening"
)

# Dovish language: phrases associated with easing bias, below-target
# inflation, and support for growth or liquidity.
dove_terms <- c(
  "cut rates", "rate cuts", "ease", "easing", "accommodative",
  "support growth", "support recovery", "disinflation",
  "inflation falling", "below target", "provide liquidity",
  "stimulus", "quantitative easing", "lower for longer"
)

hawk_rx <- paste(hawk_terms, collapse = "|")
dove_rx <- paste(dove_terms, collapse = "|")
```

## Score Top-10 Speakers

```{r score_top10}
# Restrict scoring to the top-10 most frequent speakers for tractability
top10_speakers <- speeches %>%
  count(author, sort = TRUE) %>%
  slice_head(n = 10) %>%
  pull(author)

sp_top10 <- speeches %>%
  filter(author %in% top10_speakers)

# Score each speech: hawk_score = hawk_hits / (hawk_hits + dove_hits)
# Speeches with no keyword matches receive a neutral score of 0.5.
sp_top10 <- sp_top10 %>%
  mutate(
    t          = tolower(text),
    hawk_hits  = stringr::str_count(t, stringr::regex(hawk_rx, ignore_case = TRUE)),
    dove_hits  = stringr::str_count(t, stringr::regex(dove_rx, ignore_case = TRUE)),
    total_hits = hawk_hits + dove_hits,
    hawk_score = dplyr::if_else(total_hits > 0, hawk_hits / total_hits, 0.5)
  )

toned_out <- sp_top10 %>%
  select(date_parsed, author, title, hawk_hits, dove_hits, hawk_score)

readr::write_csv(toned_out, "tables/hawk_dove_scores_top10.csv")
```

