```{r snippet_helpers}
# Return short text windows around matched phrases for manual validation
get_snippets <- function(txt, patterns, window = 50) {
  rx <- paste(patterns, collapse = "|")
  m  <- stringr::str_locate_all(
    string  = tolower(txt),
    pattern = stringr::regex(rx, ignore_case = TRUE)
  )[[1]]
  if (is.null(dim(m)) || nrow(m) == 0) return(character(0))
  purrr::pmap_chr(as.data.frame(m), function(start, end) {
    s       <- max(1, start - window)
    e       <- min(nchar(txt), end + window)
    snippet <- substr(txt, s, e)
    snippet <- gsub("\\s+", " ", snippet)
    paste0("…", snippet, "…")
  })
}

get_full_text <- function(row) {
  speeches %>%
    filter(
      date_parsed == row$date_parsed,
      author      == row$author,
      title       == row$title
    ) %>%
    slice_head(n = 1) %>%
    pull(text) %>%
    as.character()
}
```

```{r validate_examples}
hawk_row  <- most_hawkish %>% slice(1)
dove_row  <- most_dovish  %>% slice(1)

hawk_text <- get_full_text(hawk_row)
dove_text <- get_full_text(dove_row)

hawk_snips <- get_snippets(hawk_text, hawk_terms, window = 60)
dove_snips <- get_snippets(dove_text, dove_terms, window = 60)

# Print first three snippets from each to confirm matching is working correctly
hawk_snips[1:3]
dove_snips[1:3]
```

