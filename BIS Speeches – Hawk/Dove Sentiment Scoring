## Speaker Trend Analysis

```{r speaker_annual}
annual_speaker <- sp_top10 %>%
  group_by(author, year) %>%
  summarise(
    avg_score  = mean(hawk_score, na.rm = TRUE),
    n_speeches = n(),
    .groups    = "drop"
  )

head(annual_speaker)
```

```{r speaker_trends}
# OLS regression of annual average hawk_score on year, separately per speaker.
# The slope indicates whether a speaker's tone became more hawkish or dovish
# over the sample period.
trend_results <- annual_speaker %>%
  group_by(author) %>%
  do({
    model <- lm(avg_score ~ year, data = .)
    tibble(
      slope   = coef(model)[["year"]],
      p_value = summary(model)$coefficients["year", "Pr(>|t|)"]
    )
  }) %>%
  ungroup()

trend_results
```

```{r plot_speaker_trends}
# Select the three speakers with the most years of data for plotting
selected_speakers <- annual_speaker %>%
  group_by(author) %>%
  summarise(n_years = n_distinct(year), .groups = "drop") %>%
  filter(n_years >= 2) %>%
  arrange(desc(n_years)) %>%
  slice_head(n = 3) %>%
  pull(author)

plot_data <- annual_speaker %>%
  filter(author %in% selected_speakers, !is.na(year), !is.na(avg_score))

if (nrow(plot_data) == 0) {
  message("No data available for selected speakers.")
} else {
  ggplot(plot_data, aes(x = year, y = avg_score, color = author, group = author)) +
    geom_line(na.rm = TRUE) +
    geom_point(na.rm = TRUE) +
    labs(
      title = "Average Hawkishness Score by Year – Selected Speakers",
      y     = "Average hawkishness (0 = dovish, 1 = hawkish)",
      x     = "Year"
    ) +
    theme_minimal()
}
```

# Part B: Full Corpus Scoring

```{r score_full_corpus}
# Apply the same hawk/dove scoring to all speeches (not just top-10 speakers)
speeches <- speeches %>%
  mutate(
    text_lc    = tolower(text),
    hawk_hits  = stringr::str_count(text_lc, stringr::regex(hawk_rx, ignore_case = TRUE)),
    dove_hits  = stringr::str_count(text_lc, stringr::regex(dove_rx, ignore_case = TRUE)),
    total_hits = hawk_hits + dove_hits,
    hawk_score = dplyr::if_else(total_hits > 0, hawk_hits / total_hits, 0.5)
  )
```

# Part C: Country-Level Analysis

```{r country_year}
country_year <- speeches %>%
  filter(country != "Unknown") %>%
  group_by(country, year) %>%
  summarise(
    avg_score  = mean(hawk_score, na.rm = TRUE),
    n_speeches = n(),
    .groups    = "drop"
  )
```

```{r country_rankings}
country_overall <- country_year %>%
  group_by(country) %>%
  summarise(mean_score = mean(avg_score, na.rm = TRUE), .groups = "drop")

top10_hawkish <- country_overall %>% arrange(desc(mean_score)) %>% slice_head(n = 10)
top10_dovish  <- country_overall %>% arrange(mean_score)       %>% slice_head(n = 10)

top10_hawkish
top10_dovish
```

```{r country_stability}
# Countries with the lowest standard deviation in annual hawk_score
# are interpreted as having the most consistent monetary policy communication.
country_stability <- country_year %>%
  group_by(country) %>%
  summarise(sd_score = sd(avg_score, na.rm = TRUE), .groups = "drop")

top10_stable <- country_stability %>% arrange(sd_score) %>% slice_head(n = 10)
top10_stable
```

